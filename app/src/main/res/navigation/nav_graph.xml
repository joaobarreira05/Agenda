<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.agenda.app.presentation.home.HomeFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_home">
        
        <action
            android:id="@+id/action_homeFragment_to_recordFragment"
            app:destination="@id/recordFragment" />
            
        <action
            android:id="@+id/action_homeFragment_to_categoryListFragment"
            app:destination="@id/categoryListFragment" />
            
        <action
            android:id="@+id/action_homeFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
            
        <action
            android:id="@+id/action_homeFragment_to_confirmationFragment"
            app:destination="@id/confirmationFragment" />
    </fragment>

    <fragment
        android:id="@+id/recordFragment"
        android:name="com.agenda.app.presentation.record.RecordFragment"
        android:label="@string/record_voice"
        tools:layout="@layout/fragment_record">
        
        <action
            android:id="@+id/action_recordFragment_to_confirmationFragment"
            app:destination="@id/confirmationFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <fragment
        android:id="@+id/confirmationFragment"
        android:name="com.agenda.app.presentation.confirmation.ConfirmationFragment"
        android:label="Confirmar Lembrete"
        tools:layout="@layout/fragment_confirmation">
        <argument
            android:name="transcribedText"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <argument
            android:name="reminderId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <fragment
        android:id="@+id/categoryListFragment"
        android:name="com.agenda.app.presentation.category.CategoryListFragment"
        android:label="@string/categories"
        tools:layout="@layout/fragment_category_list" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.agenda.app.presentation.settings.SettingsFragment"
        android:label="Definições"
        tools:layout="@layout/fragment_settings">
        
        <action
            android:id="@+id/action_settingsFragment_to_categoryListFragment"
            app:destination="@id/categoryListFragment" />
    </fragment>

</navigation>
