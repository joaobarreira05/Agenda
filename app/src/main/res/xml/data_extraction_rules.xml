<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (API 31+).
    Controls what data is included in cloud and device-to-device transfers.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="agenda_database" />
        <include domain="sharedpref" path="." />
        <exclude domain="file" path="audio/" />
        <exclude domain="cache" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="agenda_database" />
        <include domain="sharedpref" path="." />
        <include domain="file" path="audio/" />
        <exclude domain="cache" path="." />
    </device-transfer>
</data-extraction-rules>
